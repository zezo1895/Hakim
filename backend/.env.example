# ── Database (خدمة MySQL خارجية) ─────────────────────────
DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=hakim_group
DB_SSL=true

# ── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# ── Admin ────────────────────────────────────────────────
ADMIN_SECRET=choose-a-long-random-secret

# ── CORS ─────────────────────────────────────────────────
# دومين/دومينات الفرونت اند على Vercel (مفصولة بفاصلة لو أكتر من واحد)
FRONTEND_URL=https://your-frontend.vercel.app

# Render بيحدد PORT تلقائيًا، مش محتاج تحطها يدوي
